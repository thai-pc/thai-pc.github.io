---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl bg-accent px-6 py-14 sm:px-12 sm:py-16 text-center shadow-xl shadow-accent/25">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-white/10 blur-2xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -left-16 w-72 h-72 rounded-full bg-black/10 blur-3xl pointer-events-none"></div>
      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">{t('cta.headline')}</h2>
        <p class="mt-4 text-lg text-white/90 max-w-2xl mx-auto">{t('cta.sub')}</p>
        <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`/${lang}/#install`}
            class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 font-medium text-accent shadow-lg hover:bg-white/90 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            {t('cta.primary')}
          </a>
          <a
            href="https://github.com/thai-pc/fluxfiles#readme"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-white/40 px-6 py-3 font-medium text-white hover:bg-white/10 transition-colors"
          >
            {t('cta.secondary')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
