---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const repoBase = 'https://github.com/thai-pc/fluxfiles';
const repoBranch = 'master';
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-surface-dark">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex flex-col items-center sm:items-start gap-2">
        <a href={`/${lang}/`} class="flex items-center gap-1 text-lg font-bold tracking-tight">
          <span class="text-accent">Flux</span><span class="text-gray-600 dark:text-gray-400">Files</span>
        </a>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          {t('footer.made_by')} <a href="https://github.com/thai-pc" target="_blank" rel="noopener noreferrer" class="text-accent dark:text-accent-dark hover:underline">thai-pc</a>
          &nbsp;·&nbsp;
          {t('footer.license')}
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500 max-w-sm text-center sm:text-left">
          <a href={`${repoBase}#readme`} target="_blank" rel="noopener noreferrer" class="hover:text-accent dark:hover:text-accent-dark underline-offset-2 hover:underline">{t('footer.readme_hint')}</a>
        </p>
      </div>

      <div class="flex flex-col items-center sm:items-end gap-3">
        <div class="flex flex-wrap items-center justify-center sm:justify-end gap-x-6 gap-y-2">
          <a href={`${repoBase}#readme`} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('footer.docs')}</a>
          <a href={repoBase} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">GitHub</a>
          <a href={`${repoBase}/blob/${repoBranch}/CHANGELOG.md`} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('footer.changelog')}</a>
          <a href={`${repoBase}/blob/${repoBranch}/LICENSE`} target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('footer.license_link')}</a>
        </div>
        <div class="flex flex-wrap items-center justify-center sm:justify-end gap-x-4 gap-y-1">
          <a href="https://packagist.org/packages/fluxfiles/fluxfiles" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-400 dark:text-gray-500 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('footer.packagist')}</a>
          <a href="https://www.npmjs.com/package/fluxfiles" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-400 dark:text-gray-500 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('footer.npm')}</a>
          <a href="https://www.npmjs.com/package/@fluxfiles/react" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-400 dark:text-gray-500 hover:text-accent dark:hover:text-accent-dark transition-colors">@fluxfiles/react</a>
          <a href="https://www.npmjs.com/package/@fluxfiles/vue" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-400 dark:text-gray-500 hover:text-accent dark:hover:text-accent-dark transition-colors">@fluxfiles/vue</a>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-800 text-center">
      <p class="text-xs text-gray-400 dark:text-gray-500">
        &copy; {new Date().getFullYear()} FluxFiles. Open source under MIT License.
      </p>
    </div>
  </div>
</footer>
