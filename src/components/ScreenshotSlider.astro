---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const screenshots = [
  { src: '/demo/fluxfiles-demo-desktop.png', alt: 'FluxFiles desktop file manager UI' },
  { src: '/demo/fluxfiles-demo-mobile.png', alt: 'FluxFiles mobile file manager UI' },
  { src: '/demo/fluxfiles-demo-modal.png', alt: 'FluxFiles create folder modal' },
];
---

<section class="py-16 sm:py-20" aria-label="Product screenshots">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-light dark:bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:text-accent-dark mb-4">
        {t('demo.label')}
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100">
        {t('demo.headline')}
      </h2>
    </div>

    <div
      class="rounded-xl border border-[var(--border-default)] bg-[var(--bg-elevated)] overflow-hidden shadow-lg shadow-black/5 dark:shadow-black/30"
      data-screenshot-carousel
    >
      <div class="relative">
        <div class="flex transition-transform duration-300 ease-out will-change-transform" data-carousel-track>
          {screenshots.map((img, idx) => (
            <figure class="w-full shrink-0" data-carousel-slide>
              <div class="w-full aspect-[4/3] sm:aspect-[16/9] lg:aspect-[21/9] bg-[var(--bg-page)]">
                <img
                  src={img.src}
                  alt={img.alt}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-contain cursor-zoom-in"
                  data-carousel-image={idx}
                />
              </div>
            </figure>
          ))}
        </div>

        <button
          type="button"
          class="absolute left-3 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-9 h-9 rounded-full border border-[var(--border-default)] bg-[var(--bg-page)]/90 text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-page)] transition-colors backdrop-blur"
          aria-label="Previous screenshot"
          data-carousel-prev
        >
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L8.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        </button>
        <button
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-9 h-9 rounded-full border border-[var(--border-default)] bg-[var(--bg-page)]/90 text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-page)] transition-colors backdrop-blur"
          aria-label="Next screenshot"
          data-carousel-next
        >
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 11-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      <div class="flex items-center justify-center gap-2 py-3 border-t border-[var(--border-default)] bg-[var(--bg-elevated)]" data-carousel-dots>
        {screenshots.map((_, idx) => (
          <button
            type="button"
            class="w-2.5 h-2.5 rounded-full border border-[var(--border-default)] bg-[var(--bg-page)] hover:bg-[var(--bg-subtle)] transition-colors"
            aria-label={`Go to screenshot ${idx + 1}`}
            data-carousel-dot={idx}
          />
        ))}
      </div>
    </div>

    <div
      class="fixed inset-0 z-[60] hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
      data-carousel-modal
      role="dialog"
      aria-modal="true"
      aria-label="Screenshot preview"
    >
      <div class="absolute inset-0" data-carousel-modal-backdrop></div>

      <div class="relative w-full max-w-6xl">
        <div class="rounded-xl border border-[var(--border-default)] bg-[var(--bg-page)] shadow-2xl overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--border-default)] bg-[var(--bg-elevated)]">
            <div class="text-sm font-medium" style="color: var(--text-secondary);">
              Screenshot
            </div>
            <button
              type="button"
              class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--border-default)] bg-[var(--bg-page)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-subtle)] transition-colors"
              aria-label="Close preview"
              data-carousel-modal-close
            >
              <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>

          <div class="relative bg-[var(--bg-page)]">
            <div class="w-full aspect-[4/3] sm:aspect-[16/9] bg-[var(--bg-page)]">
              <img
                src={screenshots[0].src}
                alt={screenshots[0].alt}
                class="h-full w-full object-contain"
                data-carousel-modal-image
              />
            </div>

            <button
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--border-default)] bg-[var(--bg-page)]/90 text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-page)] transition-colors backdrop-blur"
              aria-label="Previous screenshot"
              data-carousel-modal-prev
            >
              <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L8.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
              </svg>
            </button>
            <button
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-10 h-10 rounded-full border border-[var(--border-default)] bg-[var(--bg-page)]/90 text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-page)] transition-colors backdrop-blur"
              aria-label="Next screenshot"
              data-carousel-modal-next
            >
              <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 11-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-screenshot-carousel]').forEach(function (root) {
      var track = root.querySelector('[data-carousel-track]');
      var slides = root.querySelectorAll('[data-carousel-slide]');
      var btnPrev = root.querySelector('[data-carousel-prev]');
      var btnNext = root.querySelector('[data-carousel-next]');
      var dots = root.querySelectorAll('[data-carousel-dot]');
      if (!track || !slides.length) return;

      var index = 0;
      var images = root.querySelectorAll('[data-carousel-image]');
      var modal = root.querySelector('[data-carousel-modal]');
      var modalImg = root.querySelector('[data-carousel-modal-image]');
      var modalClose = root.querySelector('[data-carousel-modal-close]');
      var modalBackdrop = root.querySelector('[data-carousel-modal-backdrop]');
      var modalPrev = root.querySelector('[data-carousel-modal-prev]');
      var modalNext = root.querySelector('[data-carousel-modal-next]');
      var previouslyFocused = null;

      function clamp(n) {
        return Math.max(0, Math.min(slides.length - 1, n));
      }
      function render() {
        track.style.transform = 'translateX(-' + index * 100 + '%)';
        dots.forEach(function (d, i) {
          d.style.background = i === index ? 'var(--progress-fill)' : 'var(--bg-page)';
          d.setAttribute('aria-current', i === index ? 'true' : 'false');
        });
      }
      function goTo(n) {
        index = clamp(n);
        render();
      }
      function setModalImage() {
        if (!modalImg) return;
        var active = images[index];
        if (!active) return;
        modalImg.setAttribute('src', active.getAttribute('src') || '');
        modalImg.setAttribute('alt', active.getAttribute('alt') || 'Screenshot');
      }
      function openModal() {
        if (!modal) return;
        previouslyFocused = document.activeElement;
        setModalImage();
        modal.classList.remove('hidden');
        (modalClose || modal).focus && (modalClose || modal).focus();
      }
      function closeModal() {
        if (!modal) return;
        modal.classList.add('hidden');
        if (previouslyFocused && previouslyFocused.focus) previouslyFocused.focus();
      }

      btnPrev && btnPrev.addEventListener('click', function () { goTo(index - 1); });
      btnNext && btnNext.addEventListener('click', function () { goTo(index + 1); });
      dots.forEach(function (d) {
        d.addEventListener('click', function () {
          var raw = d.getAttribute('data-carousel-dot');
          goTo(raw ? parseInt(raw, 10) : 0);
        });
      });
      images.forEach(function (img) {
        img.addEventListener('click', function () {
          var raw = img.getAttribute('data-carousel-image');
          var n = raw ? parseInt(raw, 10) : 0;
          goTo(n);
          openModal();
        });
      });
      modalClose && modalClose.addEventListener('click', closeModal);
      modalBackdrop && modalBackdrop.addEventListener('click', closeModal);
      modalPrev && modalPrev.addEventListener('click', function () { goTo(index - 1); setModalImage(); });
      modalNext && modalNext.addEventListener('click', function () { goTo(index + 1); setModalImage(); });

      root.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft') goTo(index - 1);
        if (e.key === 'ArrowRight') goTo(index + 1);
      });
      document.addEventListener('keydown', function (e) {
        if (!modal || modal.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowLeft') { goTo(index - 1); setModalImage(); }
        if (e.key === 'ArrowRight') { goTo(index + 1); setModalImage(); }
      });

      render();
    });
  });
</script>

