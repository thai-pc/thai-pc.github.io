---
import { useTranslations, languages, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const langEntries = Object.entries(languages) as [Lang, string][];
---

<nav
  class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-surface-dark/80 backdrop-blur-sm"
  x-data="{ open: false }"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href={`/${lang}/`} class="flex items-center gap-1 text-xl font-bold tracking-tight">
        <span class="text-accent">Flux</span><span class="text-gray-600 dark:text-gray-400">Files</span>
      </a>

      <div class="hidden md:flex items-center gap-6">
        <a href="https://github.com/thai-pc/fluxfiles#readme" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('nav.docs')}</a>
        <a href="#install" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('nav.install')}</a>
        <a
          href="https://github.com/thai-pc/fluxfiles"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors"
        >
          {t('nav.github')}
          <img
            src="https://img.shields.io/github/stars/thai-pc/fluxfiles?style=flat&color=1A56A0"
            alt="GitHub stars"
            class="h-5"
            loading="lazy"
          />
        </a>

        <select
          class="text-sm border border-gray-200 dark:border-gray-700 rounded-md px-2 py-1 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100"
          onchange="window.location.href = '/' + this.value + '/'"
        >
          {langEntries.map(([code, label]) => (
            <option value={code} selected={code === lang}>{label}</option>
          ))}
        </select>

        <button
          type="button"
          class="theme-cycle p-2 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors"
          aria-label="Color theme"
        >
          <svg class="theme-icon theme-icon-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="theme-icon theme-icon-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <svg class="theme-icon theme-icon-system" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </button>
      </div>

      <button
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        @click="open = !open"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path x-show="open" x-cloak stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div
      x-show="open"
      x-cloak
      x-transition
      class="md:hidden pb-4 border-t border-gray-200 dark:border-gray-800"
    >
      <div class="flex flex-col gap-3 pt-4">
        <a href="https://github.com/thai-pc/fluxfiles#readme" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark">{t('nav.docs')}</a>
        <a href="#install" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark">{t('nav.install')}</a>
        <a href="https://github.com/thai-pc/fluxfiles" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark">
          {t('nav.github')}
        </a>
        <select
          class="text-sm border border-gray-200 dark:border-gray-700 rounded-md px-2 py-1 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 w-fit"
          onchange="window.location.href = '/' + this.value + '/'"
        >
          {langEntries.map(([code, label]) => (
            <option value={code} selected={code === lang}>{label}</option>
          ))}
        </select>
        <button
          type="button"
          class="theme-cycle p-2 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors w-fit"
          aria-label="Color theme"
        >
          <svg class="theme-icon theme-icon-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="theme-icon theme-icon-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <svg class="theme-icon theme-icon-system" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>
