---
import { getLangFromUrl, useTranslations, languages, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const langEntries = Object.entries(languages) as [Lang, string][];
---

<nav
  class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-surface-dark/80 backdrop-blur-sm"
  x-data="{ open: false }"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href={`/fluxfiles/${lang}/`} class="flex items-center gap-1 text-xl font-bold tracking-tight">
        <span class="text-accent">Flux</span><span class="text-gray-600 dark:text-gray-400">Files</span>
      </a>

      <div class="hidden md:flex items-center gap-6">
        <a href="#features" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('nav.docs')}</a>
        <a href="#install" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors">{t('nav.install')}</a>
        <a
          href="https://github.com/thai-pc/fluxfiles"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark transition-colors"
        >
          {t('nav.github')}
          <img
            src="https://img.shields.io/github/stars/thai-pc/fluxfiles?style=flat&color=1A56A0"
            alt="GitHub stars"
            class="h-5"
            loading="lazy"
          />
        </a>

        <select
          class="text-sm bg-transparent border border-gray-200 dark:border-gray-700 rounded-md px-2 py-1 text-gray-600 dark:text-gray-400 focus:outline-none focus:ring-1 focus:ring-accent"
          onchange="window.location.href = '/fluxfiles/' + this.value + '/'"
        >
          {langEntries.map(([code, label]) => (
            <option value={code} selected={code === lang}>{label}</option>
          ))}
        </select>

        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="p-2 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="hidden dark:block w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
          </svg>
          <svg class="block dark:hidden w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
          </svg>
        </button>
      </div>

      <button
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        @click="open = !open"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path x-show="open" x-cloak stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div
      x-show="open"
      x-cloak
      x-transition
      class="md:hidden pb-4 border-t border-gray-200 dark:border-gray-800"
    >
      <div class="flex flex-col gap-3 pt-4">
        <a href="#features" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent">{t('nav.docs')}</a>
        <a href="#install" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent">{t('nav.install')}</a>
        <a href="https://github.com/thai-pc/fluxfiles" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-accent">
          {t('nav.github')}
        </a>
        <select
          class="text-sm bg-transparent border border-gray-200 dark:border-gray-700 rounded-md px-2 py-1 text-gray-600 dark:text-gray-400 w-fit"
          onchange="window.location.href = '/fluxfiles/' + this.value + '/'"
        >
          {langEntries.map(([code, label]) => (
            <option value={code} selected={code === lang}>{label}</option>
          ))}
        </select>
        <button
          id="theme-toggle-mobile"
          aria-label="Toggle dark mode"
          class="p-2 rounded-lg border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors w-fit"
        >
          <svg class="hidden dark:block w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
          </svg>
          <svg class="block dark:hidden w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.querySelectorAll('#theme-toggle, #theme-toggle-mobile').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var html = document.documentElement;
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
    });
  });
</script>
