---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="live-demo" class="py-16 sm:py-24 bg-gray-50/50 dark:bg-gray-900/50">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-light dark:bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:text-accent-dark mb-4">
        {t('live.label')}
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
        {t('live.headline')}
      </h2>
      <p class="mt-4 text-gray-600 dark:text-gray-400">
        {t('live.sub')}
      </p>
    </div>

    <div class="rounded-xl border border-[var(--border-default)] bg-[var(--bg-elevated)] overflow-hidden shadow-xl shadow-black/5 dark:shadow-black/30">
      <!-- faux browser chrome to underline "this is embedded" -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-[var(--border-default)] bg-[var(--bg-page)]">
        <span class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
        </span>
        <code class="ml-2 text-xs text-gray-400 dark:text-gray-500 truncate">&lt;iframe src=&quot;https://your-app.com/files&quot;&gt;</code>
      </div>
      <iframe
        data-demo-frame
        title="FluxFiles interactive demo"
        loading="lazy"
        class="w-full h-[560px] sm:h-[640px] bg-white dark:bg-gray-950"
      ></iframe>
      <noscript>
        <iframe src="/demo-app/" title="FluxFiles interactive demo" class="w-full h-[560px] sm:h-[640px]"></iframe>
      </noscript>
    </div>

    <p class="text-center mt-5 text-sm text-gray-500 dark:text-gray-400">{t('live.hint')}</p>
  </div>

  <script is:inline>
    (function () {
      var frame = document.querySelector('[data-demo-frame]');
      if (!frame) return;
      var theme = function () { return document.documentElement.classList.contains('dark') ? 'dark' : 'light'; };
      // Load the demo already in the host's theme (no flash), then keep it in sync.
      frame.src = '/demo-app/?theme=' + theme();
      var sync = function () {
        try { frame.contentWindow.postMessage({ type: 'fluxfiles-theme', theme: theme() }, '*'); } catch (e) {}
      };
      frame.addEventListener('load', sync);
      new MutationObserver(sync).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    })();
  </script>
</section>
