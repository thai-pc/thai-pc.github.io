---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const points = [
  { key: 'p1', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6l2 2h6a2 2 0 012 2v3m-2 12V9' },
  { key: 'p2', icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z' },
  { key: 'p3', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1' },
  { key: 'p4', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2' },
];
---

<section id="byob" class="py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-light dark:bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:text-accent-dark mb-4">
        {t('byob.label')}
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
        {t('byob.headline')}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {t('byob.sub')}
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <!-- Value points -->
      <ul class="space-y-6">
        {points.map((p) => (
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-accent/10 text-accent dark:text-accent-dark flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={p.icon} /></svg>
            </span>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white">{t(`byob.${p.key}_title`)}</h3>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{t(`byob.${p.key}_desc`)}</p>
            </div>
          </li>
        ))}
      </ul>

      <!-- Diagram: app -> FluxFiles -> each tenant's own bucket -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-gray-50/60 dark:bg-gray-900/40 p-6 sm:p-8">
        <div class="flex flex-col items-center text-center">
          <div class="w-full max-w-xs rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-3 font-medium text-gray-900 dark:text-gray-100 shadow-sm">
            {t('byob.diag_app')}
          </div>

          <div class="flex flex-col items-center py-1 text-gray-400 dark:text-gray-500">
            <span class="text-[11px] font-mono">{t('byob.diag_token')}</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
          </div>

          <div class="w-full max-w-xs rounded-lg bg-accent text-white px-4 py-3 font-semibold shadow-lg shadow-accent/20">
            {t('byob.diag_core')}
            <div class="text-[11px] font-normal opacity-90 mt-0.5">{t('byob.diag_runtime')}</div>
          </div>

          <svg class="w-5 h-5 my-1 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>

          <div class="grid grid-cols-3 gap-3 w-full">
            {['A', 'B', 'C'].map((tn) => (
              <div class="rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-2 py-3 text-center">
                <div class="text-xs font-semibold text-gray-900 dark:text-gray-100">{t('byob.diag_tenant')} {tn}</div>
                <div class="mt-1 inline-flex items-center gap-1 text-[11px] text-emerald-600 dark:text-emerald-400">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 00-2 2v8a2 2 0 002 2h14a2 2 0 002-2v-8a2 2 0 00-2-2M5 8V6a2 2 0 012-2h10a2 2 0 012 2v2" /></svg>
                  {t('byob.diag_bucket')}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <p class="mt-10 mx-auto max-w-3xl text-center text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
      {t('byob.how')}
    </p>
  </div>
</section>
