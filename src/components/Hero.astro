---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden pt-16 pb-20 sm:pt-24 sm:pb-28">
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-accent-light/50 to-transparent dark:from-accent/10 dark:to-transparent"></div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-light dark:bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent dark:text-accent-dark mb-8">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      {t('hero.badge')}
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-white max-w-4xl mx-auto leading-tight">
      {t('hero.headline')}
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
      {t('hero.sub')}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`/${lang}/#install`}
        class="inline-flex items-center gap-2 bg-accent text-white font-medium rounded-lg px-6 py-3 hover:bg-accent/90 transition-colors shadow-lg shadow-accent/20"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        {t('hero.cta_start')}
      </a>
      <a
        href="https://github.com/thai-pc/fluxfiles"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg px-6 py-3 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
        {t('hero.cta_github')}
      </a>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-2 max-w-4xl mx-auto px-2">
      <a href="https://packagist.org/packages/fluxfiles/fluxfiles" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/packagist/v/fluxfiles/fluxfiles?label=packagist&color=f28d1a" alt="Packagist fluxfiles/fluxfiles" height="20" loading="lazy" />
      </a>
      <a href="https://packagist.org/packages/fluxfiles/laravel" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/packagist/v/fluxfiles/laravel?label=laravel&color=ff2d20" alt="Packagist fluxfiles/laravel" height="20" loading="lazy" />
      </a>
      <a href="https://www.npmjs.com/package/fluxfiles" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/npm/v/fluxfiles?label=sdk&color=cb3837" alt="npm fluxfiles" height="20" loading="lazy" />
      </a>
      <a href="https://www.npmjs.com/package/@fluxfiles/react" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/npm/v/@fluxfiles/react?label=react&color=61dafb" alt="npm @fluxfiles/react" height="20" loading="lazy" />
      </a>
      <a href="https://www.npmjs.com/package/@fluxfiles/vue" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/npm/v/@fluxfiles/vue?label=vue&color=42b883" alt="npm @fluxfiles/vue" height="20" loading="lazy" />
      </a>
      <a href="https://packagist.org/packages/fluxfiles/fluxfiles" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/packagist/php-v/fluxfiles/fluxfiles?color=777bb4" alt="PHP version" height="20" loading="lazy" />
      </a>
      <a href="https://github.com/thai-pc/fluxfiles/blob/master/LICENSE" target="_blank" rel="noopener noreferrer" class="opacity-90 hover:opacity-100 transition-opacity">
        <img src="https://img.shields.io/github/license/thai-pc/fluxfiles" alt="License" height="20" loading="lazy" />
      </a>
    </div>

    <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-2xl mx-auto">
      <div class="text-center">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">PHP ≥ 8.1</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{t('hero.stat_php')}</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">~3 KB</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{t('hero.stat_sdk')}</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">MIT</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{t('hero.stat_oss')}</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-gray-900 dark:text-white">16</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{t('hero.stat_lang')}</div>
      </div>
    </div>
  </div>
</section>
