---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const composerCode = `composer require fluxfiles/fluxfiles
cp .env.example .env

# .env
FLUXFILES_SECRET=your-random-32-char-secret
FLUXFILES_ALLOWED_ORIGINS=https://yourapp.com

require_once 'vendor/autoload.php';

$token = fluxfiles_token(
    userId: 'user-123',
    perms: ['read', 'write', 'delete'],
    disks: ['local', 's3', 'r2'],
    prefix: 'user-123/',
    maxUploadMb: 10,
    allowedExt: null,
    ttl: 3600
);`;

const laravelCode = `composer require fluxfiles/laravel
php artisan vendor:publish --tag=fluxfiles-config

# .env — point the adapter at your FluxFiles server
FLUXFILES_ENDPOINT=https://fm.yourdomain.com
FLUXFILES_SECRET=your-secret-min-32-chars

# Optional: match CORS on the FluxFiles host
# FLUXFILES_ALLOWED_ORIGINS=https://yourapp.com

# Config: config/fluxfiles.php`;

const sdkCode = `<!-- Demo: unpkg. In production, serve fluxfiles.js from your FluxFiles host -->
<script src="https://unpkg.com/fluxfiles@1.22.0/fluxfiles.js"><\/script>

<script>
FluxFiles.open({
    endpoint: 'https://your-api.com',
    token: 'eyJhbGci...',
    disk: 'local',
    mode: 'picker',
    container: '#file-picker',
    onSelect: function(file) {
        console.log('Selected:', file.url);
    },
    async onTokenRefresh() {
        const r = await fetch('/api/auth/refresh-fluxfiles-token');
        const { token } = await r.json();
        return token;
    }
});
<\/script>`;

const reactCode = `npm install @fluxfiles/react

import { FluxFilesModal } from '@fluxfiles/react';

<FluxFilesModal
    open={open}
    endpoint="https://your-api.com"
    token={token}
    onSelect={(file) => console.log(file)}
    onClose={() => setOpen(false)}
/>`;

const vueCode = `npm install @fluxfiles/vue

<script setup>
import { FluxFilesModal } from '@fluxfiles/vue';
<\/script>

<FluxFilesModal
    v-model:open="open"
    endpoint="https://your-api.com"
    :token="token"
    @select="onSelect"
    @close="open = false"
/>`;

const manualCode = `git clone https://github.com/thai-pc/fluxfiles.git
cd fluxfiles
composer install -d packages/core
cp .env.example .env

cd packages/core
php -S localhost:8080 router.php

# UI:  http://localhost:8080/public/index.html
# API: http://localhost:8080/api/fm/list?disk=local&path=`;

const tabs = [
  { id: 'composer', label: t('install.tab_composer'), code: composerCode },
  { id: 'laravel',  label: t('install.tab_laravel'),  code: laravelCode },
  { id: 'sdk',      label: t('install.tab_sdk'),      code: sdkCode },
  { id: 'react',    label: 'React',                   code: reactCode },
  { id: 'vue',      label: 'Vue',                     code: vueCode },
  { id: 'manual',   label: t('install.tab_manual'),   code: manualCode },
];

const frameworks = [
  { name: 'Laravel', color: 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400' },
  { name: 'WordPress', color: 'bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400' },
  { name: 'React / Next.js', color: 'bg-cyan-50 dark:bg-cyan-900/20 text-cyan-700 dark:text-cyan-400' },
  { name: 'Vue / Nuxt', color: 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400' },
  { name: 'CKEditor 4', color: 'bg-orange-50 dark:bg-orange-900/20 text-orange-700 dark:text-orange-400' },
  { name: 'TinyMCE', color: 'bg-violet-50 dark:bg-violet-900/20 text-violet-700 dark:text-violet-400' },
  { name: 'Any framework', color: 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300' },
];
---

<section id="install" class="py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-light dark:bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:text-accent-dark mb-4">
        {t('install.label')}
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
        {t('install.headline')}
      </h2>
    </div>

    <div class="mx-auto max-w-3xl" x-data="{ tab: 'composer' }">
      <div class="flex border-b border-gray-200 dark:border-gray-700 mb-0 overflow-x-auto">
        {tabs.map((tb) => (
          <button
            x-on:click={`tab = '${tb.id}'`}
            x-bind:class={`tab === '${tb.id}' ? 'border-accent text-accent dark:text-accent-dark' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'`}
            class="px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition-colors whitespace-nowrap"
          >
            {tb.label}
          </button>
        ))}
      </div>

      <div class="relative">
        {tabs.map((tb, i) => (
          <div
            x-show={`tab === '${tb.id}'`}
            x-cloak={i > 0 ? true : undefined}
            class="relative"
          >
            <div class="rounded-b-xl p-4 overflow-x-auto bg-[var(--code-bg)] text-[var(--code-text)] ring-1 ring-[var(--code-border)] shadow-inner">
              <pre class="text-sm font-mono leading-relaxed"><code id={`code-${tb.id}`}>{tb.code}</code></pre>
            </div>
            <button
              type="button"
              onclick={`copyCode('${tb.id}')`}
              class="absolute top-3 right-3 px-3 py-1 text-xs font-medium rounded-md transition-colors bg-[var(--copy-btn-bg)] text-[var(--copy-btn-text)] hover:bg-[var(--copy-btn-bg-hover)] disabled:opacity-50 disabled:pointer-events-none"
              data-copy-btn={tb.id}
            >
              {t('install.copy')}
            </button>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{t('install.works_with')}</p>
        <div class="flex flex-wrap justify-center gap-2">
          {frameworks.map((fw) => (
            <span class:list={['px-3 py-1.5 rounded-full text-xs font-medium', fw.color]}>
              {fw.name}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  function copyCode(tab) {
    var code = document.getElementById('code-' + tab);
    if (!code) return;
    navigator.clipboard.writeText(code.textContent || '').then(function() {
      var btn = document.querySelector('[data-copy-btn="' + tab + '"]');
      if (!btn) return;
      var original = btn.textContent;
      btn.textContent = '\u2713 Copied!';
      setTimeout(function() { btn.textContent = original; }, 2000);
    });
  }
</script>
